# Local preset for scripts.train_vertex (not deploy.py / not Vertex cloud)
#
# Usage (single GPU):
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
# uv run python -m scripts.train_vertex $(awk '!/^($|#)/{printf "%s ",$0}' presets/deploy_l4x2_student.args)
#
# Usage (2 GPUs local DDP):
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
# uv run python -m torch.distributed.run --nproc_per_node=2 --module scripts.train_vertex \
#   $(awk '!/^($|#)/{printf "%s ",$0}' presets/deploy_l4x2_student.args)
#
# NOTE:
# - Set --bin_path to your local packed data.bin path before running.
# - block_size must match the block size used to build the bin.

--bin_path /media/prasanna/716F26140AED9B67/datasets/data.bin
--device cuda
--seed 42
--num_workers 8

# Student model
--n_layer 12
--n_embd 768
--n_head 12
--block_size 1024

# Batching
--train_batch_size 1
--eval_batch_size 1
--grad_accum_steps 64
--validation_batch_count 20
--val_ratio 0.2

# Optimizer / schedule (10k smooth + faster convergence tuning)
--optimizer adamw
--lr 2.2e-4
--eps 1e-8
--weight_decay 0.1
--grad_clip_norm 1.0
--use_amp 1
--amp_dtype float16
--enable_gradient_checkpointing 1
--total_steps 10000
--warmup_steps 500

# Logging / artifacts (local)
--ckpt_dir ./output/mini-math-student-local-10k
--ckpt_interval_steps 2500
--save_optimizer_state 1
--log_interval_steps 100
--enable_tensorboard 0
--tensorboard_hist_interval_steps 500
--enable_vertex 0
--enable_metrics 0 

# Resume options: 
--resume_from ./output/mini-math-student-local-10k/model_5000.pt


# If you still hit OOM:
# - keep block_size fixed to match bin
# - run single GPU first
# - lower grad_accum only after OOM is gone
