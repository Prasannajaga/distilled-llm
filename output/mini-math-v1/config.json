{
  "device": "cuda",
  "seed": 42,
  "mixed_precision": true,
  "num_workers": 4,
  "n_layer": 12,
  "n_embd": 512,
  "n_head": 8,
  "block_size": 256,
  "train_batch_size": 16,
  "eval_batch_size": 8,
  "grad_accum_steps": 4,
  "validation_batch_count": 20,
  "optimizer": "adamw",
  "lr": 0.0005,
  "betas": [
    0.9,
    0.95
  ],
  "eps": 1e-08,
  "weight_decay": 0.1,
  "grad_clip_norm": 1.0,
  "use_amp": true,
  "enable_gradient_checkpointing": true,
  "amp_dtype": "bfloat16",
  "clear_cache_interval": 100,
  "log_memory_usage": true,
  "total_steps": 10000,
  "warmup_steps": 1000,
  "ckpt_dir": "./output/mini-math-v1",
  "ckpt_interval_steps": 5000,
  "save_optimizer_state": true,
  "enable_logging": true,
  "log_interval_steps": 500,
  "log_per_iteration_time": false,
  "max_new_tokens": 512,
  "temperature": 0.7,
  "use_top_k": true,
  "top_k": 50,
  "use_repetition_penalty": true,
  "repetition_penalty": 1.2,
  "stop_on_eos": true
}